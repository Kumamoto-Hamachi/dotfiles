{
  "permissions": {
    "allow": [
      "Read(*)",
      "Bash(ls:*)",
      "Bash(chmod:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(less:*)",
      "Bash(more:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(cut:*)",
      "Bash(awk:*)",
      "Bash(sed:*)",
      "Bash(which:*)",
      "Bash(whoami:*)",
      "Bash(pwd:*)",
      "Bash(date:*)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(ln:*)",
      "Bash(touch:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(diff:*)",
      "Bash(git switch:*)",
      "Bash(git add:*)",
      "Bash(git pull:*)",
      "Bash(git commit:*)",
      "Bash(git log:*)",
      "Bash(git wt:*)",
      "Bash(gh issue create:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue status:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr status:*)",
      "Bash(gh pr checkout:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git reset --soft:*)",
      "Bash(tfenv install:*)",
      "Bash(terraform validate:*)",
      "Bash(terraform providers lock:*)",
      "Bash(tflint:*)",
      "Bash(terraform init:*)",
      "Bash(terraform plan:*)",
      "Bash(terraform fmt:*)",
      "mcp__github__pull_request_read",
      "mcp__github__get_me",
      "mcp__github__get_commit",
      "mcp__github__get_file_contents",
      "mcp__github__get_label",
      "mcp__github__get_tag",
      "mcp__github__list_branches",
      "mcp__github__list_commits",
      "mcp__github__list_issues",
      "mcp__github__list_pull_requests",
      "mcp__github__search_code",
      "mcp__github__search_issues",
      "mcp__github__search_pull_requests",
      "mcp__github__search_repositories",
      "mcp__sentry__analyze_issue_with_seer",
      "mcp__sentry__find_organizations",
      "mcp__sentry__find_projects",
      "mcp__sentry__find_releases",
      "mcp__sentry__find_teams",
      "mcp__sentry__get_doc",
      "mcp__sentry__get_event_attachment",
      "mcp__sentry__get_issue_details",
      "mcp__sentry__get_issue_tag_values",
      "mcp__sentry__get_trace_details",
      "mcp__sentry__search_docs",
      "mcp__sentry__search_events",
      "mcp__sentry__search_issue_events",
      "mcp__sentry__search_issues",
      "mcp__sentry__whoami",
      "mcp__plugin_slack_slack__*",
      "WebFetch(domain:docs.aws.amazon.com)",
      "WebFetch(domain:docs.sentry.io)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:stackoverflow.com)",
      "WebFetch(domain:registry.terraform.io)",
      "WebFetch(domain:code.claude.com)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(terraform apply:*)",
      "Bash(terraform destroy:*)",
      "Bash(terraform state:*)",
      "Bash(terraform import:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)"
    ],
    "ask": [
      "Bash(mv:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(git push:*)",
      "mcp__plugin_slack_slack__slack_send_message",
      "mcp__plugin_slack_slack__slack_send_message_draft",
      "mcp__plugin_slack_slack__slack_schedule_message",
      "mcp__plugin_slack_slack__slack_create_canvas",
      "mcp__plugin_slack_slack__slack_update_canvas"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "terraform-mcp-server",
    "github",
    "terraform"
  ],
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "if [[ \"$CLAUDE_FILE_PATH\" == *.tf ]]; then terraform fmt \"$CLAUDE_FILE_PATH\" 2>/dev/null; fi"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "claude-md-management@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "hookify@claude-plugins-official": true
  }
}
